#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_ACCOUNTS 100

struct clientData
{
    unsigned int acctNum;
    char firstName[20];
    char lastName[20];
    char jointName[20];
    char password[20];
    double balance;
};

// Function Prototypes
unsigned int enterChoice(void);
void initializeFile(FILE *fPtr);
void createAccount(FILE *fPtr);
void depositRecord(FILE *fPtr);
void withdrawRecord(FILE *fPtr);
void deleteRecord(FILE *fPtr);
void displayAccounts(FILE *fPtr);
int login(FILE *fPtr, struct clientData *client);
void writeHistory(unsigned int accNo, char action[], double amount);
void showHistory(unsigned int accNo);
void checkBalance(FILE *fPtr);

// -------------------- MAIN --------------------
int main()
{
    FILE *cfPtr;

    cfPtr = fopen("credit.dat", "rb+");

    if (cfPtr == NULL)
    {
        cfPtr = fopen("credit.dat", "wb+");

        if (cfPtr == NULL)
        {
            printf("File could not be opened.\n");
            return 1;
        }

        initializeFile(cfPtr);
    }

    unsigned int choice;

    while ((choice = enterChoice()) != 8)
    {
        switch (choice)
        {
        case 1:
            createAccount(cfPtr);
            break;

        case 2:
            depositRecord(cfPtr);
            break;

        case 3:
            withdrawRecord(cfPtr);
            break;

        case 4:
            displayAccounts(cfPtr);
            break;

        case 5:
            deleteRecord(cfPtr);
            break;

        case 6:
        {
            unsigned int accNo;
            printf("Enter account number: ");
            scanf("%u", &accNo);
            showHistory(accNo);
            break;
        }

        case 7:
            checkBalance(cfPtr);
            break;

        default:
            printf("Invalid choice.\n");
        }
    }

    fclose(cfPtr);

    return 0;
}

// -------------------- MENU --------------------
unsigned int enterChoice(void)
{
    unsigned int choice;

    printf("\n===== JOINT BANK MANAGEMENT SYSTEM =====\n");
    printf("1 - Create Account\n");
    printf("2 - Deposit Money\n");
    printf("3 - Withdraw Money\n");
    printf("4 - Display Accounts\n");
    printf("5 - Delete Account\n");
    printf("6 - Transaction History\n");
    printf("7 - Check Balance\n");
    printf("8 - Exit\n");
    printf("Enter your choice: ");

    scanf("%u", &choice);

    return choice;
}

// -------------------- INITIALIZE FILE --------------------
void initializeFile(FILE *fPtr)
{
    struct clientData blank = {0, "", "", "", "", 0.0};

    rewind(fPtr);

    for (int i = 0; i < MAX_ACCOUNTS; i++)
    {
        fwrite(&blank, sizeof(struct clientData), 1, fPtr);
    }
}

// -------------------- CREATE ACCOUNT --------------------
void createAccount(FILE *fPtr)
{
    unsigned int account;
    struct clientData client;

    printf("Enter account number (1-100): ");
    scanf("%u", &account);

    if (account < 1 || account > MAX_ACCOUNTS)
    {
        printf("Invalid account number.\n");
        return;
    }

    fseek(fPtr,
          (account - 1) * sizeof(struct clientData),
          SEEK_SET);

    fread(&client,
          sizeof(struct clientData),
          1,
          fPtr);

    if (client.acctNum != 0)
    {
        printf("Account already exists.\n");
        return;
    }

    client.acctNum = account;

    printf("Enter first name: ");
    scanf("%19s", client.firstName);

    printf("Enter last name: ");
    scanf("%19s", client.lastName);

    printf("Enter joint account holder name: ");
    scanf("%19s", client.jointName);

    printf("Create password: ");
    scanf("%19s", client.password);

    printf("Enter initial balance: ");
    scanf("%lf", &client.balance);

    fseek(fPtr,
          (account - 1) * sizeof(struct clientData),
          SEEK_SET);

    fwrite(&client,
           sizeof(struct clientData),
           1,
           fPtr);

    writeHistory(account, "Account Created", client.balance);

    printf("Account created successfully.\n");
}

// -------------------- LOGIN --------------------
int login(FILE *fPtr, struct clientData *client)
{
    unsigned int account;
    char password[20];

    printf("Enter account number: ");
    scanf("%u", &account);

    printf("Enter password: ");
    scanf("%19s", password);

    if (account < 1 || account > MAX_ACCOUNTS)
    {
        printf("Invalid account number.\n");
        return 0;
    }

    fseek(fPtr,
          (account - 1) * sizeof(struct clientData),
          SEEK_SET);

    fread(client,
          sizeof(struct clientData),
          1,
          fPtr);

    if (client->acctNum == 0)
    {
        printf("Account does not exist.\n");
        return 0;
    }

    if (strcmp(client->password, password) != 0)
    {
        printf("Wrong password.\n");
        return 0;
    }

    return 1;
}

// -------------------- DEPOSIT --------------------
void depositRecord(FILE *fPtr)
{
    struct clientData client;
    double amount;

    if (!login(fPtr, &client))
    {
        return;
    }

    printf("Current Balance: %.2f\n", client.balance);

    printf("Enter deposit amount: ");
    scanf("%lf", &amount);

    client.balance += amount;

    fseek(fPtr,
          (client.acctNum - 1) * sizeof(struct clientData),
          SEEK_SET);

    fwrite(&client,
           sizeof(struct clientData),
           1,
           fPtr);

    writeHistory(client.acctNum, "Deposit", amount);

    printf("Deposit successful.\n");
    printf("New Balance: %.2f\n", client.balance);
}

// -------------------- WITHDRAW --------------------
void withdrawRecord(FILE *fPtr)
{
    struct clientData client;
    double amount;

    if (!login(fPtr, &client))
    {
        return;
    }

    printf("Current Balance: %.2f\n", client.balance);

    printf("Enter withdraw amount: ");
    scanf("%lf", &amount);

    if (amount > client.balance)
    {
        printf("Insufficient balance.\n");
        return;
    }

    client.balance -= amount;

    fseek(fPtr,
          (client.acctNum - 1) * sizeof(struct clientData),
          SEEK_SET);

    fwrite(&client,
           sizeof(struct clientData),
           1,
           fPtr);

    writeHistory(client.acctNum, "Withdraw", amount);

    printf("Withdraw successful.\n");
    printf("Remaining Balance: %.2f\n", client.balance);
}

// -------------------- DISPLAY ACCOUNTS --------------------
void displayAccounts(FILE *fPtr)
{
    struct clientData client;

    rewind(fPtr);

    printf("\n%-6s %-15s %-15s %-15s %-10s\n",
           "AccNo",
           "First Name",
           "Last Name",
           "Joint Name",
           "Balance");

    while (fread(&client,
                 sizeof(struct clientData),
                 1,
                 fPtr) == 1)
    {
        if (client.acctNum != 0)
        {
            printf("%-6u %-15s %-15s %-15s %.2f\n",
                   client.acctNum,
                   client.firstName,
                   client.lastName,
                   client.jointName,
                   client.balance);
        }
    }
}

// -------------------- DELETE ACCOUNT --------------------
void deleteRecord(FILE *fPtr)
{
    struct clientData client;
    struct clientData blank = {0, "", "", "", "", 0.0};

    if (!login(fPtr, &client))
    {
        return;
    }

    fseek(fPtr,
          (client.acctNum - 1) * sizeof(struct clientData),
          SEEK_SET);

    fwrite(&blank,
           sizeof(struct clientData),
           1,
           fPtr);

    writeHistory(client.acctNum, "Account Deleted", 0);

    printf("Account deleted successfully.\n");
}

// -------------------- WRITE HISTORY --------------------
void writeHistory(unsigned int accNo, char action[], double amount)
{
    FILE *historyPtr;

    historyPtr = fopen("history.txt", "a");

    if (historyPtr == NULL)
    {
        printf("Unable to open history file.\n");
        return;
    }

    fprintf(historyPtr,
            "Account No: %u | %s | Amount: %.2f\n",
            accNo,
            action,
            amount);

    fclose(historyPtr);
}

// -------------------- CHECK BALANCE --------------------
void checkBalance(FILE *fPtr)
{
    struct clientData client;

    if (!login(fPtr, &client))
    {
        return;
    }

    printf("===== ACCOUNT DETAILS =====");
    printf("Account Number : %u", client.acctNum);
    printf("Account Holder : %s %s",
           client.firstName,
           client.lastName);
    printf("Joint Holder   : %s", client.jointName);
    printf("Current Balance: %.2f", client.balance);
}

// -------------------- SHOW HISTORY --------------------
void showHistory(unsigned int accNo)
{
    FILE *historyPtr;
    char line[200];
    char search[50];

    historyPtr = fopen("history.txt", "r");

    if (historyPtr == NULL)
    {
        printf("No transaction history found.\n");
        return;
    }

    sprintf(search, "Account No: %u", accNo);

    printf("\n===== TRANSACTION HISTORY =====\n");

    while (fgets(line, sizeof(line), historyPtr) != NULL)
    {
        if (strstr(line, search) != NULL)
        {
            printf("%s", line);
        }
    }

    fclose(historyPtr);
}
